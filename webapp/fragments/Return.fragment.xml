
<core:FragmentDefinition
    controllerName="com.applexus.finalproject.fragments.Return"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

<SplitApp id="splitApp">

    <!-- ================= MASTER ================= -->
    <masterPages>
        <Page title="Bookings">

            <content>

                <SearchField 
                    placeholder="Search customer..." 
                    width="70%"
                    liveChange="onMasterSearch"
                    class="sapUiSmallMargin"/>

                <List 
                    id="bookingList"
                    items="{/Zib18_g4_return_master}"
                    mode="SingleSelectMaster"
                    selectionChange="onSelectBooking">

                    <items>
                        <StandardListItem
                            title="{BookingID}"
                            description="{CustomerName}"
                            info="{Status}"
                            infoState="Success"/>
                    </items>

                </List>

            </content>

        </Page>
    </masterPages>


    <!-- ================= DETAIL ================= -->
    <detailPages>
        <Page id="detailPage" title="Return Details">

            <content>

                <VBox class="sapUiSmallMargin">

                    <!-- HEADER -->
                    <HBox class="sapUiSmallMarginBottom">

                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Customer ID"/>
                            <Input value="{CustomerID}" editable="false"/>
                        </VBox>

                        <VBox>
                            <Label text="Customer Name"/>
                            <Input value="{CustomerName}" editable="false"/>
                        </VBox>

                    </HBox>

                    <!-- TABLE -->
                    <Table id="returnTable" items="{itemsModel>/}">

                        <columns>
                            <Column><Text text="Item"/></Column>
                            <Column><Text text="Total Qty"/></Column>
                            <Column><Text text="Status"/></Column>
                            <Column><Text text="Condition"/></Column>
                            <Column><Text text="Left Qty"/></Column>
                            <Column><Text text="Return Date"/></Column>
                            <Column><Text text="Returned Qty"/></Column>
                            <Column><Text text="Fine"/></Column>
                            <Column><Text text="Action"/></Column>
                        </columns>

                        <items>
                            <ColumnListItem>

                                <cells>

                                    <!-- Item -->
                                    <VBox>
                                        <Text text="{itemsModel>ItemName}"/>
                                        <Text text="{itemsModel>ItemType}" class="sapUiTinyMarginTop"/>
                                    </VBox>

                                    <!-- Total Qty -->
                                    <Text text="{itemsModel>Quantity}"/>

                                    <!-- Status -->
                                    <Select 
                                        selectedKey="{itemsModel>Status}" 
                                        change="onStatusChange"
                                        >

                                        <items>
                                            <core:Item key="R" text="Returned"/>
                                            <core:Item key="L" text="Lost"/>
                                            <core:Item key="P" text="Partially Returned"/>
                                        </items>

                                    </Select>

                                    <!-- Condition -->
                                <Select selectedKey="{itemsModel>Conditions}" 
                                        enabled="{= ${itemsModel>Status} !== 'L' }">
                                    <items>
                                        <core:Item key="G" text="Good"/>
                                        <core:Item key="B" text="Damaged"/>
                                    </items>
                                </Select>

                                     <!-- Left Qty -->
                                    <Text text="{itemsModel>LeftQty}"/>

                                    <!-- Date -->
                                    <DatePicker 
                                        value="{itemsModel>ReturnDate}" 
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="dd-MM-yyyy"
                                        minDate="{todayModel>/minReturnDate}" 
                                        editable="{= ${itemsModel>Status} !== 'L' }"/>

                                    <!-- Returned Qty -->
                                    <Input 
                                        value="{itemsModel>ReturnedQty}" 
                                        type="Number" 
                                        width="80px"
                                        />

                                    <!-- Fine -->
                                    <Text text="{itemsModel>CalculatedFine}"/>
                                    <Button 
                                            text="Save" 
                                            type="Emphasized"
                                            press="onRowSave"
                                           />
                                </cells>

                            </ColumnListItem>
                        </items>

                    </Table>

                    <!-- 
                    <HBox justifyContent="End" class="sapUiMediumMarginTop">
                        <Button text="Save" type="Emphasized" press="onSave"/>
                    </HBox> -->

                </VBox>
                <VBox visible="{= ${itemsModel>/allReturned} === true }">

                    <Text text="Total Fine: {itemsModel>/totalFine}" />
                    <Text text="Refund Amount: {itemsModel>/refund}" />

                </VBox>

            </content>

        </Page>
    </detailPages>

</SplitApp>

</core:FragmentDefinition>

