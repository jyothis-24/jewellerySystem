
<core:FragmentDefinition
    controllerName="com.applexus.finalproject.fragments.Return"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Page title="Return Details">

    <content>
        <VBox class="sapUiSmallMarginBegin sapUiMarginTop">
        <!-- SEARCH -->
        <SearchField 
            placeholder="Search customer..." 
            width="30%" 
            class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>

        <!-- HEADER DETAILS -->
        <HBox class="sapUiSmallMarginBottom " justifyContent="Start">

        <VBox class="sapUiSmallMarginEnd">
              <Label text="Customer ID"/>
             <Input value="{/customerId}" editable="false"/>
    </VBox>

    <VBox>
        <Label text="Customer Name"/>
        <Input value="{/customerName}" editable="false"/>
    </VBox>

      </HBox>
      </VBox>

        <!-- TABLE -->
        <Table items="{/items}" class="sapUiSmallMarginTop">

            <columns>
                <Column><Text text="Item Description"/></Column>
                <Column><Text text="Total Qty"/></Column>
                <Column><Text text="Return Status"/></Column>
                <Column><Text text="Condition"/></Column>
                <Column><Text text="Return Date"/></Column>
                <Column><Text text="Returned Qty"/></Column>
            </columns>

            <items>
                <ColumnListItem>

                    <cells>

                        <!-- Description -->
                        <VBox>
                            <Text text="{name}"/>
                            <Text text="{type}" class="sapUiTinyMarginTop"/>
                        </VBox>

                        <!-- Qty -->
                        <Text text="{qty}"/>

                        <!-- Return Status -->
                        <Select 
                            selectedKey="{status}" 
                            change="onStatusChange">

                            <items>
                                <core:Item key="RETURNED" text="Returned"/>
                                <core:Item key="MISSING" text="Missing"/>
                                <core:Item key="PARTIAL" text="Partial"/>
                            </items>

                        </Select>

                        <!-- Condition -->
                        <Select 
                            selectedKey="{condition}"
                            enabled="{= ${status} !== 'MISSING'}">

                            <items>
                                <core:Item key="GOOD" text="Good"/>
                                <core:Item key="DAMAGED" text="Damaged"/>
                              
                            </items>

                        </Select>

                        <!-- Return Date -->
                        <DatePicker value="{itemReturnDate}" displayFormat="dd-MM-yyyy"/>

                        <!-- Returned Qty -->
                        <Input value="{returnedQty}" type="Number" width="80px"/>

                    </cells>

                </ColumnListItem>
            </items>

        </Table>

        <!-- BUTTON -->
        <HBox justifyContent="End" class="sapUiSmallMarginTop sapUiLargeMarginEnd">
            <Button text="save" type="Emphasized" press="onComplete"  width="90px"/>
        </HBox>

    </content>
            </Page>
</core:FragmentDefinition>


 
