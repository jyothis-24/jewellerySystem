<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">

<Dialog id="addItemDialog" title="Add New Inventory Item">

    <VBox class="sapUiSmallMargin">

        <!-- Product Name -->
        <Label text="Product Name" required="true" class="sapUiTinyMarginTop"/>
        <Input 
            id="inputItemName"
            placeholder="Enter product name" 
            value="{newItem>/item_name}"
            liveChange="onNewItemLiveChange"/>

        <!-- Product Type -->
        <Label text="Product Type" required="true" class="sapUiTinyMarginTop"/>
        <Select 
            id="selectType"
            selectedKey="{newItem>/type}"
            width="100%">
            <core:Item key="" text="-- Select Type --"/>
            <core:Item key="Oxidised Silver" text="Oxidised Silver"/>
            <core:Item key="Hand Made" text="Hand Made"/>
        </Select>

        <!-- Category -->
        <Label text="Category" required="true" class="sapUiTinyMarginTop"/>
        <Select 
            id="selectCategory"
            selectedKey="{newItem>/category}"
            width="100%">
            <core:Item key="" text="-- Select Category --"/>
            <core:Item key="Traditional" text="Traditional"/>
            <core:Item key="Modern" text="Modern"/>
            <core:Item key="Ethnic" text="Ethnic"/>
            <core:Item key="Wedding" text="Wedding"/>
        </Select>

        <!-- Quantity Unit -->
        <Label text="Quantity Unit" required="true" class="sapUiTinyMarginTop"/>
        <Select 
            id="selectUnit"
            selectedKey="{newItem>/quant_unit}"
            width="100%">
            <core:Item key="" text="-- Select Unit --"/>
            <core:Item key="PC"  text="Pieces"/>
            <core:Item key="PAA" text="Pairs"/>
        </Select>

        <!-- Total Qty -->
        <Label text="Total Quantity" required="true" class="sapUiTinyMarginTop"/>
        <Input 
            id="inputTotalQty"
            type="Number" 
            placeholder="Enter total quantity" 
            value="{newItem>/total_qty}"
            liveChange="onNewItemLiveChange"/>

        <!-- Available Qty -->
        <Label text="Available Quantity" required="true" class="sapUiTinyMarginTop"/>
        <Input 
            id="inputAvailableQty"
            type="Number" 
            placeholder="Enter available quantity" 
            value="{newItem>/available_qty}"
            liveChange="onNewItemLiveChange"/>

        <!-- Rent Per Day -->
        <Label text="Rent Per Day" required="true" class="sapUiTinyMarginTop"/>
        <Input 
            id="inputRentPerDay"
            type="Number" 
            placeholder="Enter rent per day" 
            value="{newItem>/rent_per_day}"
            liveChange="onNewItemLiveChange"/>

        <!-- Deposit -->
        <Label text="Deposit Amount" required="true" class="sapUiTinyMarginTop"/>
        <Input 
            id="inputDeposit"
            type="Number" 
            placeholder="Enter deposit amount" 
            value="{newItem>/deposit}"
            liveChange="onNewItemLiveChange"/>

        <!-- Image URL -->
        <Label text="Image URL" class="sapUiTinyMarginTop"/>
        <TextArea 
            id="inputImageUrl"
            placeholder="Enter image URL (optional)" 
            value="{newItem>/image_url}" 
            width="100%"/>

    </VBox>

    <beginButton>
        <Button text="Save" type="Accept" press="onSaveNewItem"/>
    </beginButton>
    <endButton>
        <Button text="Cancel" press="onCloseDialog"/>
    </endButton>

</Dialog>

</core:FragmentDefinition>