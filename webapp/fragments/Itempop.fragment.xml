<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">

<Dialog id="addItemDialog" title="Add New Inventory Item">

    <VBox class="sapUiSmallMargin">

        <!-- <Input placeholder="ID" value="{newItem>/item_id}" /> -->

        <Input placeholder="Product Name" value="{newItem>/item_name}" />

        <!-- Product Type -->
        <Select selectedKey="{newItem>/type}">
            <core:Item key="Oxidised Silver" text="Oxidised Silver"/>
            <core:Item key="Hand Made" text="Hand Made"/>
        </Select>

        <!-- Category -->
        <Select selectedKey="{newItem>/category}">
            <core:Item key="Traditional" text="Traditional"/>
            <core:Item key="Modern" text="Modern"/>
            <core:Item key="Ethnic" text="Ethnic"/>
            <core:Item key="Wedding" text="Wedding"/>
        </Select>

       <!-- Quantity Unit -->
        <Select selectedKey="{newItem>/quant_unit}">
            <core:Item key="PC" text="Pieces"/>
            <core:Item key="PAA" text="Pairs"/>
        </Select>

        <!-- Total Qty -->
        <Input type="Number" placeholder="Total Quantity" value="{newItem>/total_qty}" />

        <!-- Available Qty -->
        <Input type="Number" placeholder="Available Quantity" value="{newItem>/available_qty}" />

        <!-- Rent -->
        <Input type="Number" placeholder="Rent Per Day" value="{newItem>/rent_per_day}" />

       <!-- Deposit -->
<Input type="Number" placeholder="Deposit Amount" value="{newItem>/deposit}" />

      <!-- Currency -->
<!-- <Select selectedKey="{newItem>/curr_key}">
    <core:Item key="INR" text="INR"/>
    <core:Item key="USD" text="USD"/>
</Select> -->

        <!-- Image URL -->
        <TextArea placeholder="Image URL" value="{newItem>/image_url}"  width="100%"/>

    </VBox>

    <beginButton>
        <Button text="Save" type="Accept" press="onSaveNewItem"/>
    </beginButton>

    <endButton>
        <Button text="Cancel" press="onCloseDialog"/>
    </endButton>

</Dialog>

</core:FragmentDefinition>