<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <VBox>

        <Toolbar>

         <Button 
            icon="sap-icon://sort"
            tooltip="Sort by Booking ID"
            press="onSortBooking"
            class="sapUiSmallMarginEnd"/>

            <Title text="Booking Management" level="H2" />
            <ToolbarSpacer />

            <SearchField
                width="150px"
                placeholder="Search Id or Booking"
                liveChange="onSearch"/>

            <Select change="onFilterChange">
                <items>
                    <core:Item key="all" text="All Status"/>
                    <core:Item key="pending" text="Pending"/>
                    <core:Item key="approved" text="Approved"/>
                    <core:Item key="rejected" text="Rejected"/>
                </items>
            </Select>
        </Toolbar>

        <Table id="bookingTable" items="{grouped>/}" class="sapUiSmallMarginTop"
        growing="true" growingThreshold="8" growingScrollToLoad="false">

            <columns>
                <Column><Text text="BOOKING ID"/></Column>
                <Column><Text text="CUSTOMER NAME"/></Column>
                <Column><Text text="ITEMS SELECTED"/></Column>
                <Column hAlign="Center"><Text text="BOOKED QUANTITY"/></Column>
                <Column><Text text="DATES"/></Column>
                <Column><Text text="STATUS"/></Column>
                <Column><Text text="PAYMENT STATUS"/></Column>
                <Column><Text text="ADMIN OPTIONS"/></Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>

                        <Text text="{grouped>BookingID}"/>
                        <Text text="{grouped>CustomerFullName}"/>

                        <!-- ITEMS -->
                        <VBox>
                            <List items="{grouped>Items}">
                                <items>
                                    <CustomListItem>
                                        <HBox>
                                            <Text text="{grouped>ItemDescription}"/>
                                            <!-- <Text text=" (Qty: {grouped>Quantity})"/> -->
                                        </HBox>
                                    </CustomListItem>
                                </items>
                            </List>
                        </VBox>

                        <!--  NEW CELL -->
                        <Text text="{
                            path: 'grouped>Items',
                            formatter: '.formatTotalQty'
                        }"/>

                        <!-- Dates -->
                        <VBox>
                            <Text text="{
                                path: 'grouped>RentalStartDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd-MM-yyyy' }
                            }"/>

                            <Text text="{
                                path: 'grouped>RentalEndDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd-MM-yyyy' }
                            }"/>
                        </VBox>

                        <!-- STATUS -->
                        <ObjectStatus
                            text="{grouped>BookingStatusDescription}"
                            state="{= ${grouped>BookingCurrentStatus} === 'A' ? 'Success' :
                                      ${grouped>BookingCurrentStatus} === 'P' ? 'Warning' :
                                      ${grouped>BookingCurrentStatus} === 'R' ? 'Error' :
                                      ${grouped>BookingCurrentStatus} === 'B' ? 'Information' : 'None' }"/>

                        <!-- PAYMENT STATUS -->
                        <ObjectStatus
                            text="{grouped>PaymentStatusDescription}"
                            state="{= ${grouped>PaymentCurrentStatus} === 'C' ? 'Success' :
                                      ${grouped>PaymentCurrentStatus} === 'P' ? 'Warning' : 'None' }"/>

                        <!-- ACTION BUTTONS -->
                        <HBox>
                            <Button
                                text="Approve"
                                type="Emphasized"
                                press="onApprovePress"
                                enabled="{= ${grouped>BookingCurrentStatus} === 'P' }"
                                class="sapUiSmallMarginEnd"/>

                            <Button
                                text="Reject"
                                type="Reject"
                                enabled="{= ${grouped>BookingCurrentStatus} === 'P' }"
                                press="onRejectPress"/>
                        </HBox>

                    </cells>
                </ColumnListItem>
            </items>
            

        </Table>

    </VBox>

</core:FragmentDefinition>