<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <VBox >


        <Toolbar >
            <Title text="Booking Management" level="H2" />
            <ToolbarSpacer />
            

            <SearchField
                width="250px"
                placeholder="Search..."
                liveChange="onSearch"/>

            <Select change="onFilterChange">
                <items>
                    <core:Item key="all" text="All Status"/>
                    <core:Item key="pending" text="Pending"/>
                    <core:Item key="approved" text="Approved"/>
                    <core:Item key="rejected" text="Rejected"/>
                </items>
            </Select>
        </Toolbar>

        
        <Table items="{/ZIB18_G4_Admin_Book}" class="sapUiSmallMarginTop">

            <columns>
                <Column><Text text="BOOKING ID"/></Column>
                <Column><Text text="CUSTOMER NAME"/></Column>
                <Column><Text text="ITEMS SELECTED"/></Column>
                <Column><Text text="DATES"/></Column>
                <Column><Text text="STATUS"/></Column>
                <Column><Text text="PAYMENT STATUS"/></Column>
                <Column><Text text="ADMIN OPTIONS"/></Column>
            </columns>

            <items>
                <ColumnListItem>

                    <cells>

                        
                        <Link text="{BookingID}"/>

                        
                        <Text text="{CustomerFullName}"/>

                        
                       <VBox>
                <List items="{items}">
                    <items>
                        <CustomListItem>
                            <HBox>
                                <Text text="{ItemDescription}" />
                                <Text text=" - " />
                                <Text text="{oJson>quantity}" />
                            </HBox>
                        </CustomListItem>
                    </items>
                </List>
    </VBox>

                        <!-- Dates -->
                       <VBox>
                            <Text text="{
                                path: 'RentalStartDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd-MM-yyyy' }
                            }"/>

                            <Text text="{
                                path: 'RentalEndDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd-MM-yyyy' }
                            }"/>
                        </VBox>

                        <!-- STATUS -->
                       <ObjectStatus
                                text="{BookingStatusDescription}"
                                state="{= ${BookingCurrentStatus} === 'A' ? 'Success' : ${BookingCurrentStatus} === 'P' ? 'Warning' : ${BookingCurrentStatus} === 'C' ? 'Error' :${BookingCurrentStatus} === 'B' ? 'Information' : 'None' }"/>

                        <!-- PAYMENT STATUS -->
                      <ObjectStatus
                                text="{PaymentStatusDescription}"
                                state="{= ${PaymentCurrentStatus} === 'C' ? 'Success' : ${PaymentCurrentStatus} === 'P' ? 'Warning' : 'None' }"/>
                                                            
                         

                        <!-- ACTION BUTTONS -->
                        <HBox>
                            <Button
                                text="Approve"
                                type="Emphasized"
                                press="onApprovePress"
                                enabled="{= ${BookingStatusDescription} === 'Pending' }"
                                 class = "sapUiSmallMarginEnd"/>

                            <Button
                                text="Reject"
                                type="Reject"
                                press="onRejectPress"
                                enabled="{= ${PaymentStatusDescription} === 'Pending' }"/>
                        </HBox>

                    </cells>

                </ColumnListItem>
            </items>

        </Table>

    </VBox>

</core:FragmentDefinition>