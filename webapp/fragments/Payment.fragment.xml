<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <VBox class="sapUiSmallMargin">

        <!-- Header -->
        <HBox justifyContent="SpaceBetween" alignItems="Center">
            <Title text="Payment Monitoring" level="H2"/>

            <HBox>
                <SearchField
                    width="200px"
                    placeholder="Search Customer..."
                    class="sapUiSmallMarginEnd"
                    liveChange="onSearchPay"/>
                    
                <!--  FILTER BUTTON WITH DROPDOWN -->
                <MenuButton
                    id="filterButton1"
                    text="Filter"
                    icon="sap-icon://filter">

                    <menu>
                        <Menu itemSelected="onFilterSelect">
                            <MenuItem text="All" key="ALL"/>
                            <MenuItem text="Pending" key="P"/>
                            <MenuItem text="Confirmed" key="C"/>
                        </Menu>
                    </menu>

    </MenuButton>
             
            </HBox>
        </HBox>

       <Table id="idPaymentTable" items="{/ZIB18_G4_Payment}" class="sapUiMediumMarginTop">

    <columns>
        <Column><Text text="Booking ID"/></Column>
        <Column><Text text="Customer"/></Column>
        <Column><Text text="Rent Amount"/></Column>
        <Column><Text text="Pay Date"/></Column>
        <Column><Text text="Deposit"/></Column>
        <Column><Text text="Status"/></Column>
    </columns>

    <items>
        <ColumnListItem>
            <cells>

                <!-- Booking ID -->
                <ObjectIdentifier title="{BookingID}"/>

                <!-- Customer -->
                <Text text="{CustomerName}"/>

                <!-- Rent -->
                <Text text="₹ {TotalRentalAmount}"/>

                <!-- Payment Date -->
                <Text text="{
                            path:'PaymentProcessedDate',
                            type: 'sap.ui.model.type.Date',
                            formatOptions: { pattern: 'dd-MM-yyyy' }
                        }"/>

                <!-- Deposit -->
                <Text text="₹ {TotalDepositAmount}"/>

                <!-- Status -->
                <ObjectStatus
                    text="{PaymentStatusDescription}"
                    state="{= ${PaymentCurrentStatus} === 'C' ? 'Success' :${PaymentCurrentStatus} === 'P' ? 'Warning' :'None' }"/>

            </cells>
        </ColumnListItem>
    </items>

</Table>

    </VBox>


</core:FragmentDefinition>