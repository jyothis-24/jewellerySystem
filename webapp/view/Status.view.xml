<mvc:View controllerName="com.applexus.finalproject.controller.Status"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

<Page title="Booking Status">

    <content>

        <!-- SEARCH + FILTER + Back Button -->
<HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBegin" alignItems="Center">

    <!-- Back Button -->
    <Button 
        icon="sap-icon://nav-back" 
        type="Transparent"
        press="onNavBack"/>

    <!-- Right Side Controls -->
    <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
        
        <SearchField 
            placeholder="Search by Booking ID or Item Summary..." 
            width="80%" 
            liveChange="onSearch"/>

        <Select width="200px" change="onFilter" class="sapUiTinyMarginBegin" >
            <items>
                <core:Item key="ALL" text="All Statuses" xmlns:core="sap.ui.core"/>
                <core:Item key="PENDING" text="Pending" xmlns:core="sap.ui.core"/>
                <core:Item key="APPROVED" text="Approved" xmlns:core="sap.ui.core"/>
                <core:Item key="REJECTED" text="Rejected" xmlns:core="sap.ui.core"/>
                <core:Item key="PARTIAL" text="Partially Approved" xmlns:core="sap.ui.core"/>
            </items>
        </Select>

    </HBox>

</HBox>

        <!-- TABLE -->
        <Table items="{/bookings}" class="sapUiSmallMargin">

            <columns>
                <Column><Text text="BOOKING ID"/></Column>
                <Column><Text text="ITEM LIST"/></Column>
                <Column><Text text="TOTAL PAYABLE"/></Column>
                <Column><Text text="STATUS"/></Column>
                <Column><Text text="ACTION"/></Column>
                <Column><Text text="OTHER"/></Column>
            </columns>

            <items>
                <ColumnListItem>

                    <cells>

                        <Text text="{bookingId}"/>

                        <Text text="{summary}"/>

                        <Text text="INR {amount}"/>

                       <ObjectStatus
                            text="{status}"
                                state="{
                                    path: 'status',
                                    formatter: '.formatStatusState'
                                }"/>

                        <Button 
                            text="PAY NOW" 
                            type="Emphasized"
                            enabled="{= ${status} !== 'REJECTED'}"
                            press="onPayNow"/>

                        <Button 
                            text="VIEW FINE" 
                            enabled="{= ${status} === 'APPROVED'}"
                            press="onViewFine"/>

                    </cells>

                </ColumnListItem>
            </items>

        </Table>

    </content>

</Page>
</mvc:View>