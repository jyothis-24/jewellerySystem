<mvc:View
    controllerName="com.applexus.finalproject.controller.Status"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Booking Status">

        <content>

            <!-- SEARCH + FILTER + Back Button -->
            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBegin" alignItems="Center">

                <!-- Back Button -->
                <Button
                    icon="sap-icon://nav-back"
                    type="Transparent"
                    press="onNavBack"/>

                <!-- Right Side Controls -->
                <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                    
                    <SearchField
                        placeholder="Search by Booking ID"
                        width="80%"
                        liveChange="onSearch"/>

                    <Select width="200px" change="onFilter" class="sapUiTinyMarginBegin">
                        <items>
                            <core:Item key="ALL" text="All Statuses"/>
                            <core:Item key="PENDING" text="Pending"/>
                            <core:Item key="APPROVED" text="Approved"/>
                            <core:Item key="REJECTED" text="Rejected"/>
                            <core:Item key="PARTIAL" text="Partially Approved"/>
                        </items>
                    </Select>

                </HBox>

            </HBox>

            <!-- TABLE -->
            <Table
                id="tableId"
                items="{grouped>/GroupedBookings}"
                class="sapUiSmallMargin"
                width="auto">

                <columns>
                    <Column><Text text="BOOKING ID"/></Column>
                    <Column><Text text="ITEM LIST"/></Column>
                    <Column><Text text="TOTAL PAYABLE"/></Column>
                    <Column><Text text="STATUS"/></Column>
                    <Column><Text text="ACTION"/></Column>
                </columns>

                <items>
                    <ColumnListItem>

                        <cells>

                            <!-- Booking ID -->
                            <Text text="{grouped>booking_id}"/>

                            <!-- ✅ Item list inside cell -->
                            <VBox>
                                <List items="{grouped>items}" showSeparators="None">
                                    <CustomListItem>
                                        <Text text="{grouped>}"/>
                                    </CustomListItem>
                                </List>
                            </VBox>

                            <!-- Total payable -->
                            <Text text="{path: 'grouped>total_payable', formatter: '.formatCurrency'}"/>

                            <!-- Status -->
                            <ObjectStatus
                                text="{= ${grouped>booking_status} === 'P' ? 'Pending' :
                                         ${grouped>booking_status} === 'R' ? 'Rejected' :
                                         ${grouped>booking_status} === 'A' ? 'Accepted' :
                                         ${grouped>booking_status} }"/>

                            <!-- Actions -->
                            <HBox>
                                <Button
                                    text="PAY NOW"
                                    type="Emphasized"
                                    enabled="{= ${grouped>booking_status} === 'A'}"
                                    press="onPayNow"/>

                                <Button
                                    text="VIEW FINE"
                                    enabled="{= ${grouped>booking_status} === 'A'}"
                                    press="onViewFine"
                                    class="sapUiTinyMarginBegin"/>
                            </HBox>

                        </cells>

                    </ColumnListItem>
                </items>

            </Table>

        </content>

    </Page>
</mvc:View>