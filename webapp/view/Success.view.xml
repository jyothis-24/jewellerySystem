<mvc:View controllerName="com.applexus.finalproject.controller.Success"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core='sap.ui.core'
    displayBlock="true">

<Page id="Success" showHeader="false" class="sapUiContentPadding">

<content>
<VBox 
    justifyContent="Center" 
    alignItems="Center" 
    height="100%">
        <!-- Success Icon -->
    <core:Icon 
        src="sap-icon://accept" 
        size="3rem" 
        color="green"
        class="sapUiMediumMarginBottom"/>


    <!-- Title -->
        <Text
            text="{= 'Your Booking ID: ' + ${viewModel>/bookingId}}"
            class="sapUiSmallMarginBottom"
            textAlign="Center"
            wrapping="true"
            design="Bold"
            color="Good"/>

        <!-- Description -->
        <Text 
            text="Your request has been submitted successfully. Please keep track of admin approval in your dashboard status."
            textAlign="Center"
            class="sapUiSmallMarginBottom"
            wrapping="true"/>

    <!-- Button -->
    <Button 
        text="Return to Inventory"
        type="Emphasized"
        press="onBackToInventory"/>

</VBox>
</content>

</Page>
</mvc:View>