
<mvc:View controllerName="com.applexus.finalproject.controller.Admin"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:core="sap.ui.core"   
    xmlns="sap.m">

    <Page id="Admin" title="{i18n>title}">

    <headerContent>
        <Button 
            text="Logout" 
            icon="sap-icon://log"
            press="onLogoutPress"/>
    </headerContent>

<IconTabBar>

    <items>

        <IconTabFilter text="Booking">
            <core:Fragment fragmentName="com.applexus.finalproject.fragments.Booking" type="XML"/>
        </IconTabFilter>

  <IconTabFilter text="Return">
            <core:Fragment fragmentName="com.applexus.finalproject.fragments.Return" type="XML"/>
        </IconTabFilter>

         <IconTabFilter text="Payment">
            <core:Fragment fragmentName="com.applexus.finalproject.fragments.Payment" type="XML"/>
        </IconTabFilter>

        <IconTabFilter text="Inventory">
            <core:Fragment fragmentName="com.applexus.finalproject.fragments.Inventory" type="XML"/>
        </IconTabFilter> 
       

    </items>
         
</IconTabBar>

       </Page>
</mvc:View> 