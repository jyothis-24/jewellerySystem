<mvc:View controllerName="com.applexus.finalproject.controller.Userbook"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m">
    
    <Page id="Userbook" title="Booking Details">
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- Header -->
                <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                    <Title text="Booking Details"/>
                </HBox>

                <!-- ITEMS -->
                <List items="{booking>/items}" class="sapUiSmallMarginTop">
                    <CustomListItem>
                        <VBox class="sapUiSmallMarginBottom sapUiResponsiveMargin">
                            
                            <!-- Item Header -->
                            <HBox justifyContent="SpaceBetween">
                                <VBox>
                                    <Text text="{booking>name}" />
                                    <Text text="{= ${booking>type} + ' ' + ${booking>curr_key} + ' ' + ${booking>price} + '/day' }" />
                                </VBox>
                                <VBox alignItems="End">
                                    <Text text="RENTAL QTY"/>
                                    <Input 
                                            type="Number"
                                            value="{booking>qty}"
                                            change="onQuantChange"
                                            liveChange="onQuantLiveChange"
                                            width="60px"
                                            maxLength="5"/>
                                </VBox>
                            </HBox>

                            <!-- Dates -->
                            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
                                <VBox width="48%">
                                    <Text text="START DATE"/>
                                    <DatePicker 
                                        id="startDatePicker"
                                        value="{booking>startDate}" 
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="dd-MM-yyyy"
                                        minDate="{local>/today}"
                                        change="onStartDateChange" />
                                </VBox>

                                <VBox width="48%">
                                    <Text text="END DATE"/>
                                    <DatePicker 
                                        id="endDatePicker"
                                        value="{booking>endDate}" 
                                        minDate="{local>/tomorrow}"
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="dd-MM-yyyy"
                                        change="onEndDateChange"/>
                                </VBox>
                            </HBox>

                        </VBox>
                    </CustomListItem>
                </List>

                <!-- SUMMARY BOX -->
                <VBox class="sapUiSmallMarginTop sapUiSmallMarginBottom sapUiResponsiveMargin">
                    <HBox justifyContent="SpaceBetween">
                        <Text text="Total Rent:"/>
                        <Text text="{= ${booking>/curr_key} +' ' + ${booking>/totalRent} }"/>
                    </HBox>

                    <HBox justifyContent="SpaceBetween">
                        <Text text="Security Deposit:"/>
                        <Text text="{= ${booking>/curr_key}  + ' ' + ${booking>/totalDeposit} }"/>
                    </HBox>

                    <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
                        <Text text="Total Payable:"/>
                        <ObjectStatus text="{= ${booking>/curr_key} + ' ' + ${booking>/total} }" state="Success"/>
                    </HBox>
                </VBox>

                <!-- TERMS -->
                <VBox class="sapUiSmallMarginTop">
                    <Title text="Terms &amp; Conditions"/>

                    <CheckBox id="cb1" text="I agree that there is no cancellation." select="onTermsChange"/>
                    <CheckBox id="cb2" text="I agree to pay a fine for late return." select="onTermsChange"/>
                    <CheckBox id="cb3" text="I verify that all items will be returned in original condition." select="onTermsChange"/>
                </VBox>

                <!-- FOOTER -->
                <HBox justifyContent="End" class="sapUiMediumMarginTop">
                    <Button text="Back" width="80px" class="sapUiTinyMarginEnd" press="onBack"/>
                    <Button text="Book Now" id="book" type="Emphasized" enabled="false" press="onBookNow"/>
                </HBox>

            </VBox>
        </content>
    </Page>
</mvc:View>